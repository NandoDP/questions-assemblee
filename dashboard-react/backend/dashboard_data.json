            "annotation_data": {},
            "error": null,
            "is_cached": null,
            "query": "SELECT sum(count) AS \"SUM(count)\" \nFROM (SELECT\n  d.nom AS departement,\n  d.code_region,\n  d.code_dep,\n  d.latitude,\n  d.longitude,\n  q.thematique_principale,\n  q.depute_id,\n  COUNT(q.depute_id)\nFROM questions AS q\nJOIN LATERAL UNNEST(q.departements_concernes) AS departement\n  ON TRUE\nLEFT JOIN departements AS d\n  ON d.nom = departement\nWHERE\n  NOT q.departements_concernes IS NULL\nGROUP BY\n  d.nom,\n  d.latitude,\n  d.longitude,\n  q.thematique_principale,\n  q.depute_id) AS virtual_table \n LIMIT 50000;\n\n",
            "status": "success",
            "stacktrace": null,
