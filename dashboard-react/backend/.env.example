# Configuration Backend API

# URL Superset
SUPERSET_URL=https://questions-assemblee-superset.onrender.com

# Compte de service utilisé pour créer les guest tokens.
# Ce compte doit avoir la permission Superset de générer des guest tokens.
SUPERSET_EMBED_USERNAME=embed_service
SUPERSET_EMBED_PASSWORD=change-me-embed-password
SUPERSET_EMBED_EMAIL=embed-service@example.com
SUPERSET_EMBED_ROLE_NAME=EmbeddedService
SUPERSET_DASHBOARD_ID=1

# Port API
PORT=5001

# Base de données (optionnel si accès direct)
DATABASE_URL=postgresql://...
